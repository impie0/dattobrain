# Copy this file to .env and fill in values. Never commit .env.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Password for the postgres superuser
POSTGRES_PASSWORD=

# ── Datto RMM API (used by mcp-server only) ───────────────────────────────────
# API key from Datto RMM portal: Setup → API
DATTO_API_KEY=
# API secret from Datto RMM portal: Setup → API
DATTO_API_SECRET=
# Datto RMM platform region (pinotage, merlot, concord, vidal, zinfandel, syrah)
DATTO_PLATFORM=merlot

# ── MCP Internal Security ─────────────────────────────────────────────────────
# Shared secret between mcp-bridge and mcp-server (generate with: openssl rand -hex 32)
MCP_INTERNAL_SECRET=

# ── Auth Service — RS256 JWT ──────────────────────────────────────────────────
# RSA private key (PEM format, single line with \n). Generate with:
#   openssl genrsa -out private.pem 2048
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
JWT_PRIVATE_KEY=
# RSA public key (PEM format, single line with \n). Extract with:
#   openssl rsa -in private.pem -pubout -out public.pem
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' public.pem
JWT_PUBLIC_KEY=

# ── LiteLLM Gateway ───────────────────────────────────────────────────────────
# REQUIRED for production. Without this, LiteLLM's admin API and /v1 endpoint
# are open to any process on the internal network — an API key exfiltration risk.
# Generate with: openssl rand -hex 32
# All ai-service requests automatically use this key via llmClient.
LITELLM_MASTER_KEY=

# ── LLM Provider API Keys (passed to LiteLLM) ────────────────────────────────
# OpenRouter routes Claude, DeepSeek, and Gemini through one key.
# Get key at https://openrouter.ai — required for all LLM routing.
OPENROUTER_API_KEY=
# Direct Anthropic key — only needed if using Anthropic routes in litellm/config.yaml
# that bypass OpenRouter (not required by default).
ANTHROPIC_API_KEY=
# Direct DeepSeek key — only needed if routing DeepSeek without OpenRouter.
DEEPSEEK_API_KEY=
# Direct Gemini key — only needed if routing Gemini without OpenRouter.
GEMINI_API_KEY=

# ── Embedding Service ─────────────────────────────────────────────────────────
# Embedding provider: "voyage" (default) or "openai"
EMBEDDING_PROVIDER=voyage
# API key for the embedding provider
# Voyage: https://dash.voyageai.com | OpenAI: https://platform.openai.com
EMBEDDING_API_KEY=
# Model override (defaults: voyage-3 for voyage, text-embedding-3-small for openai)
EMBEDDING_MODEL=

# ── Redis ─────────────────────────────────────────────────────────────────────
# JWT revocation (SEC-002): APISIX Lua checks Redis for revoked JTIs per request.
# Auth-service tracks issued JTIs per user for admin forced-revoke (SEC-008).
# Redis is already in the stack — set this to activate revocation.
REDIS_URL=redis://redis:6379
