# Copy this file to .env and fill in values. Never commit .env.
#
# ── DEPLOYMENT CHECKLIST ──────────────────────────────────────────────────────
# After filling in this file:
#
# 1. Update services/pgbouncer/pgbouncer.ini — set password= to match POSTGRES_PASSWORD
#    (pgbouncer.ini has a hardcoded password that must match .env or pgbouncer won't connect)
#
# 2. Run: docker compose up --build -d
#
# 3. Run: ./setup-apisix.sh
#    APISIX routes are NOT in any config file — they must be pushed via this script
#    after every fresh docker compose up. Re-running is safe (idempotent).
#
# 4. After any .env change: use  docker compose up -d <service>
#    NOT docker compose restart <service>  — restart does NOT reload env vars
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Password for the postgres superuser
POSTGRES_PASSWORD=

# ── Datto RMM API (used by mcp-server only) ───────────────────────────────────
# API key from Datto RMM portal: Setup → API
DATTO_API_KEY=
# API secret from Datto RMM portal: Setup → API
DATTO_API_SECRET=
# Datto RMM platform region (pinotage, merlot, concord, vidal, zinfandel, syrah)
DATTO_PLATFORM=merlot

# ── MCP Internal Security ─────────────────────────────────────────────────────
# Shared secret between mcp-bridge and mcp-server (generate with: openssl rand -hex 32)
MCP_INTERNAL_SECRET=

# ── Auth Service — RS256 JWT ──────────────────────────────────────────────────
# RSA private key — store as base64-encoded PEM (entire file, base64'd as one line).
# The auth service checks: if value starts with "-----" → raw PEM; else → base64 decode.
# Raw PEM with literal \n characters does NOT work. Always use base64.
# Generate with:
#   openssl genrsa -out private.pem 2048
#   base64 -w 0 private.pem    # macOS: base64 -i private.pem (no -w flag)
JWT_PRIVATE_KEY=
# RSA public key — same format: base64-encoded PEM as one line.
# Extract and encode with:
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -w 0 public.pem     # macOS: base64 -i public.pem (no -w flag)
# APISIX setup: setup-apisix.sh reads JWT_PUBLIC_KEY and passes it as a decoded PEM
# to the APISIX consumer. The script requires python3 or node to JSON-encode the key.
JWT_PUBLIC_KEY=

# ── LiteLLM Gateway ───────────────────────────────────────────────────────────
# REQUIRED for production. Without this, LiteLLM's admin API and /v1 endpoint
# are open to any process on the internal network — an API key exfiltration risk.
# MUST start with "sk-" (e.g. sk-litellm-admin or sk-<random>).
# LiteLLM rejects keys that do not match this format with a startup error.
# Generate with: echo "sk-$(openssl rand -hex 16)"
# All ai-service requests automatically use this key via llmClient.
LITELLM_MASTER_KEY=

# ── LLM Provider API Keys (passed to LiteLLM) ────────────────────────────────
# OpenRouter routes Claude, DeepSeek, and Gemini through one key.
# Get key at https://openrouter.ai — required for all LLM routing.
OPENROUTER_API_KEY=
# Direct Anthropic key — only needed if using Anthropic routes in litellm/config.yaml
# that bypass OpenRouter (not required by default).
ANTHROPIC_API_KEY=
# Direct DeepSeek key — only needed if routing DeepSeek without OpenRouter.
DEEPSEEK_API_KEY=
# Direct Gemini key — only needed if routing Gemini without OpenRouter.
GEMINI_API_KEY=

# ── Embedding Service ─────────────────────────────────────────────────────────
# Embedding provider: "voyage" (default) or "openai"
EMBEDDING_PROVIDER=voyage
# API key for the embedding provider
# Voyage: https://dash.voyageai.com | OpenAI: https://platform.openai.com
EMBEDDING_API_KEY=
# Model override (defaults: voyage-3 for voyage, text-embedding-3-small for openai)
EMBEDDING_MODEL=

# ── Redis ─────────────────────────────────────────────────────────────────────
# JWT revocation (SEC-002): APISIX Lua checks Redis for revoked JTIs per request.
# Auth-service tracks issued JTIs per user for admin forced-revoke (SEC-008).
# Redis is already in the stack — set this to activate revocation.
REDIS_URL=redis://redis:6379

# ── CVE Scanner (optional — runs automatically if cve-scanner container is started) ──
# NVD feed cache directory inside the container (default: /app/nvd-cache)
# NVD_CACHE_DIR=/app/nvd-cache
# Daily scan schedule (cron format, default: 4 AM)
# SCAN_CRON=0 4 * * *
# Minimum match confidence threshold (0.0-1.0, default: 0.70)
# MIN_CONFIDENCE=0.70
